<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="300" fill="#f3f4f6"/>
  <text x="200" y="150" text-anchor="middle" fill="#6b7280" font-family="Arial, sans-serif" font-size="16">
    Chat Bot Workflow
  </text>
  <ellipse cx="80" cy="80" rx="40" ry="30" fill="#3b82f6" opacity="0.3"/>
  <ellipse cx="200" cy="80" rx="40" ry="30" fill="#10b981" opacity="0.3"/>
  <ellipse cx="320" cy="80" rx="40" ry="30" fill="#f59e0b" opacity="0.3"/>
  <ellipse cx="80" cy="180" rx="40" ry="30" fill="#ef4444" opacity="0.3"/>
  <ellipse cx="200" cy="180" rx="40" ry="30" fill="#8b5cf6" opacity="0.3"/>
  <ellipse cx="320" cy="180" rx="40" ry="30" fill="#06b6d4" opacity="0.3"/>
  <ellipse cx="200" cy="260" rx="40" ry="30" fill="#84cc16" opacity="0.3"/>
  <text x="80" y="85" text-anchor="middle" fill="#1f2937" font-size="11">User Input</text>
  <text x="200" y="85" text-anchor="middle" fill="#1f2937" font-size="11">Analyze</text>
  <text x="320" y="85" text-anchor="middle" fill="#1f2937" font-size="11">Intent</text>
  <text x="80" y="185" text-anchor="middle" fill="#1f2937" font-size="11">Process</text>
  <text x="200" y="185" text-anchor="middle" fill="#1f2937" font-size="11">Query DB</text>
  <text x="320" y="185" text-anchor="middle" fill="#1f2937" font-size="11">Format</text>
  <text x="200" y="265" text-anchor="middle" fill="#1f2937" font-size="11">Response</text>
  <path d="M 120 80 L 160 80" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 240 80 L 280 80" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 320 110 L 320 150" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 280 180 L 240 180" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 160 180 L 120 180" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 80 210 L 80 240 L 160 240" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 200 210 L 200 230" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 320 210 L 320 240 L 240 240" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#6b7280"/>
    </marker>
  </defs>
</svg>
