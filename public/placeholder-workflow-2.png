<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="300" fill="#f3f4f6"/>
  <text x="200" y="150" text-anchor="middle" fill="#6b7280" font-family="Arial, sans-serif" font-size="16">
    Invoice Generation Workflow
  </text>
  <rect x="30" y="50" width="120" height="40" fill="#3b82f6" opacity="0.3" rx="6"/>
  <rect x="170" y="50" width="120" height="40" fill="#10b981" opacity="0.3" rx="6"/>
  <rect x="30" y="110" width="120" height="40" fill="#f59e0b" opacity="0.3" rx="6"/>
  <rect x="170" y="110" width="120" height="40" fill="#ef4444" opacity="0.3" rx="6"/>
  <rect x="30" y="170" width="120" height="40" fill="#8b5cf6" opacity="0.3" rx="6"/>
  <rect x="170" y="170" width="120" height="40" fill="#06b6d4" opacity="0.3" rx="6"/>
  <rect x="100" y="230" width="120" height="40" fill="#84cc16" opacity="0.3" rx="6"/>
  <text x="90" y="75" text-anchor="middle" fill="#1f2937" font-size="11">Import CSV</text>
  <text x="230" y="75" text-anchor="middle" fill="#1f2937" font-size="11">Parse Entries</text>
  <text x="90" y="135" text-anchor="middle" fill="#1f2937" font-size="11">Apply Rates</text>
  <text x="230" y="135" text-anchor="middle" fill="#1f2937" font-size="11">Calculate Total</text>
  <text x="90" y="195" text-anchor="middle" fill="#1f2937" font-size="11">Generate PDF</text>
  <text x="230" y="195" text-anchor="middle" fill="#1f2937" font-size="11">Quality Check</text>
  <text x="160" y="255" text-anchor="middle" fill="#1f2937" font-size="11">Save to Drive</text>
  <path d="M 150 70 L 170 70" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 230 90 L 230 110" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 170 130 L 150 130" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 90 150 L 90 170" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 150 190 L 170 190" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 230 210 L 230 230 L 220 230" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <path d="M 90 210 L 90 230 L 100 230" stroke="#6b7280" stroke-width="2" fill="none" marker-end="url(#arrow)"/>
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#6b7280"/>
    </marker>
  </defs>
</svg>
